# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
INWORLD_API_KEY="MY_INWORLD_API_KEY"

# --- Gemini Enterprise Agent Platform (optional, formerly "Vertex AI" —
# Google renamed it in 2026; same aiplatform.googleapis.com backend) ---
# If set, Gemini calls route through this platform (billed via standard
# Google Cloud billing — covered by the $300 GCP trial credit) instead of
# the AI Studio GEMINI_API_KEY's prepay plan.
#
# Express Mode (simplest): just an API key from the Agent Platform console,
# no project/service-account setup required.
GEMINI_ENTERPRISE_API_KEY=""
#
# Full mode (only needed if you want quota/IAM scoped to a specific GCP
# project instead of Express Mode's shared pool): requires a GCP project with
# billing + the platform API enabled (search "Gemini Enterprise Agent
# Platform" in Cloud Console, not "Vertex AI" — that name no longer appears
# there), and a service account (role: "Vertex AI User" — the IAM role name
# itself hasn't changed) with its JSON key downloaded. Leave both empty to
# stay on Express Mode / GEMINI_API_KEY.
GOOGLE_CLOUD_PROJECT=""
GOOGLE_CLOUD_LOCATION="us-central1"
GOOGLE_APPLICATION_CREDENTIALS=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- Welcome email (optional — signup silently skips email if absent) ---
# Resend API key (re_...) from https://resend.com/api-keys; the sending
# domain (yadira.chat) must be verified in Resend. See EMAIL-SETUP.md.
RESEND_API_KEY=""
# Optional From override; defaults to "Yadira <welcome@yadira.chat>"
EMAIL_FROM=""

# --- Firebase (optional OVERRIDE — the production web config is committed
# in src/lib/firebase.ts, so cloud sync works with these left empty; set
# them only to point a build at a different Firebase project) ---
# From Firebase Console > Project Settings > Your apps > Web app config
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_MEASUREMENT_ID=""
